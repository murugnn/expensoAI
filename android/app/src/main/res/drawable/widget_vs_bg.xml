<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    
    <!-- The Gradient: Left (Hero) to Right (Darkrai) -->
    <gradient
        android:angle="0"
        android:startColor="#203A43"
        android:centerColor="#2C5364"
        android:endColor="#0F2027"
        android:type="linear" />
    
    <!-- Rounded Corners -->
    <corners android:radius="22dp" />
    
    <!-- A subtle border to make it pop on dark wallpapers -->
    <stroke 
        android:width="1dp" 
        android:color="#33FFFFFF" />
        
    <padding
        android:left="16dp"
        android:top="16dp"
        android:right="16dp"
        android:bottom="16dp" />
</shape>